<configuration>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- Keep tests quiet: only WARN and above are printed to the console -->
  <root level="WARN">
    <appender-ref ref="STDOUT"/>
  </root>
</configuration>
